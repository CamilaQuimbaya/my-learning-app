# --- Base de datos ---
# Crea tu cadena en MongoDB Atlas. NUNCA subas el archivo .env.local a git.
MONGODB_URI="mongodb+srv://usuario:password@cluster0.xxxx.mongodb.net/edu-webdev?retryWrites=true&w=majority"

# --- NextAuth / Auth.js ---
# Genera un secreto con:  openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# En producción pon la URL pública, ej: https://tu-dominio.com
AUTH_URL="http://localhost:3000"

# --- Google OAuth (opcional) ---
# Consíguelos en https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
